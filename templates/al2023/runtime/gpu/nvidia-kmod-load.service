[Unit]
Description=Loading NVIDIA kernel modules
# Uses DMI data from sysfs for instance type detection, no network needed
Before=cloud-init.service nvidia-fabricmanager.service nvidia-persistenced.service

[Service]
Type=oneshot
ExecStart=/etc/eks/nvidia-kmod-load.sh
RemainAfterExit=true

[Install]
WantedBy=multi-user.target
